Manipulate[
 Module[{d = 1, theta1, theta2, x1, y1, shift, glass, surfaceTop, 
   surfaceBottom, normal1, normal2, rayIn, rayMid, rayOut, inDir, 
   outDir, parallelCheck},(*1. 核心参数：入射点固定在(0,0)*)
  theta1 = theta1Deg*Degree;
  theta2 = ArcSin[Sin[theta1]/n];
  (*2. 光路关键点计算*)x1 = d*Tan[theta2];
  y1 = -d;
  (*3. 侧移量计算*)shift = d*Sin[theta1 - theta2]/Cos[theta2];
  (*4. 方向向量验证平行性*)inDir = {Cos[theta1], -Sin[theta1]};
  outDir = {Cos[theta1], -Sin[theta1]};
  parallelCheck = If[Norm[inDir - outDir] < 10^-6, "✅ 严格平行", "❌ 不平行"];
  (*5. 图形元素定义*)glass = Rectangle[{-2.5, -d}, {2.5, 0}];
  surfaceTop = Line[{{-3, 0}, {3, 0}}];
  surfaceBottom = Line[{{-3, -d}, {3, -d}}];
  normal1 = Line[{{0, -0.5}, {0, 0.5}}];
  normal2 = Line[{{x1, -d - 0.5}, {x1, -d + 0.5}}];
  (*6. 光路绘制*)rayIn = Arrow[{{-2*Tan[theta1], 2}, {0, 0}}];
  rayMid = Line[{{0, 0}, {x1, y1}}];
  rayOut = Arrow[{{x1, y1}, {x1 + 2*Tan[theta1], y1 - 2}}];
  (*7. 主图形绘制*)
  Show[Graphics[{LightBlue, Opacity[0.3], glass, Thick, Black, 
     surfaceTop, surfaceBottom, Dashed, Gray, normal1, normal2, Red, 
     Thick, rayIn, Blue, Thick, rayMid, Red, Thick, rayOut, 
     Text[Style["入射点(固定)", 12, Bold, Red], {0.1, 0.2}], 
     Text[Style["空气", 14, Bold], {2, 0.5}], 
     Text[Style["玻璃(n=" <> ToString[N[n, 2]] <> ")", 14, 
       Bold], {2, -0.5}]}, PlotRange -> {{-3.5, 3.5}, {-3.5, 3.5}}, 
    ImageSize -> 700, BaseStyle -> {FontSize -> 13}],(*8. 实时数据面板*)
   Graphics[
    Inset[Grid[{{"入射角 \[Theta]₁", 
        Row[{N[theta1/Degree, 3], "°"}]}, {"折射率 n", 
        N[n, 3]}, {"折射角 \[Theta]₂", 
        Row[{N[theta2/Degree, 3], "°"}]}, {"侧移量", 
        Row[{N[shift, 3], " 单位长度"}]}, {"平行性验证", 
        parallelCheck}, {"核心规律", "出射光 \[DoubleVerticalBar] 入射光，仅侧移"}},
       Alignment -> Left, Frame -> All, Spacings -> {2, 1}, 
      BaseStyle -> {FontSize -> 
         13}], {-3.2, -3.2}]]]],(*9. 交互控件：入射角+折射率*){{theta1Deg, 30, 
   "入射角 \[Theta]₁ (°)"}, 0, 80, 1, 
  Appearance -> "Labeled"}, {{n, 1.5, "折射率 n"}, 1.0, 2.5, 0.05, 
  Appearance -> "Labeled"}, TrackedSymbols :> {theta1Deg, n}, 
 ControlPlacement -> Bottom]
